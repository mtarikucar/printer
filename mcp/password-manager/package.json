{
  "name": "claude-password-manager-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "A local, encrypted password-manager MCP server that lets Claude Code use your own credentials with per-access auditing.",
  "type": "module",
  "bin": {
    "pm-cli": "dist/cli.js",
    "claude-password-manager": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "cli": "node dist/cli.js",
    "dev:server": "tsx src/server.ts",
    "dev:cli": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx test/vault.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
