# Database (Local PostgreSQL)
DATABASE_URL=postgresql://printer:printer@localhost:5432/printer

# Redis
REDIS_URL=redis://localhost:6379

# WhatsApp (customer support link only — no longer used for payment coordination)
WHATSAPP_PHONE=905XXXXXXXXX

# PayTR (https://www.paytr.com — Turkish payment gateway, iFrame API)
#
# ⚠️ The webhook ("Bildirim URL") MUST be configured in your PayTR merchant panel
#    at: paytr.com/magaza/ayarlar
#    Set it to:  ${NEXT_PUBLIC_APP_URL}/api/webhooks/paytr
#
#    PayTR's servers can't reach localhost — for local dev, expose your server via
#    `ngrok http 3000` (or cloudflared tunnel) and point the panel at the tunnel URL.
#    Without the webhook URL configured, card payments will succeed on PayTR's side
#    but the local order will stay in `pending` forever. Use the "PayTR durumunu
#    sorgula" button on /admin/drafts/[id] to recover stuck drafts.
#
# PAYTR_TEST_MODE=1 → debug_on and test_mode are forwarded to PayTR; no real charge.
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1
PAYTR_TIMEOUT_MINUTES=30
# PAYTR_DEBUG_ON: forwarded as `debug_on` to PayTR; surfaces extra error info.
# Defaults to PAYTR_TEST_MODE if unset. Set to "0" in production to avoid
# leaking internal error details on real transactions.
PAYTR_DEBUG_ON=
# Defense-in-depth: after a webhook's hash verifies, ALSO query PayTR's
# status-query API to confirm the success/failure. Set to "0" to disable
# (e.g. load testing). Test-mode traffic always bypasses this check.
PAYTR_WEBHOOK_STATUS_CHECK=1

# Bank transfer (havale/EFT) — shown to customer when bank_transfer payment is chosen
BANK_NAME=Garanti BBVA
BANK_ACCOUNT_HOLDER=Figurine Studio Ltd.
BANK_IBAN=TR00 0000 0000 0000 0000 0000 00
BANK_BRANCH=Kadıköy / İstanbul

# AI image generation (fal.ai — photo → stylized figure image, main /create flow)
FAL_API_KEY=
# AI Provider (Meshy.ai) — still used by the Creative Lab products feature
# (keychain/magnet/lamp) until it is migrated to fal.ai.
MESHY_API_KEY=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Figurine Studio <siparis@figurunica.com>

# Auth
# AUTH_SECRET is required (≥32 chars). Used as the base secret for NextAuth
# admin sessions, and as the fallback for customer/manufacturer JWTs when their
# distinct secrets aren't set.
AUTH_SECRET=generate-a-random-secret-here
# In production, set distinct secrets per realm so a leak in one doesn't
# compromise the others. If unset, both fall back to AUTH_SECRET (env.ts logs
# a warning at boot).
CUSTOMER_JWT_SECRET=
MANUFACTURER_JWT_SECRET=
ADMIN_EMAIL=admin@figurunica.com
# Generate with: node -e "require('bcryptjs').hash('YOUR_PASSWORD', 12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Rate-limiting: comma-separated list of upstream proxy IPs we trust to set
# X-Forwarded-For / X-Real-IP. When unset, rate-limit buckets use the raw
# (spoofable) XFF first hop and emit a one-shot warn. Set in production.
# Example: TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2
TRUSTED_PROXY_IPS=

# File serving signature flags. `getPublicUrl` now embeds HMAC ?exp=&sig= in
# every URL. When FILES_REQUIRE_SIGNATURE=1 unsigned requests are rejected.
# SECURITY: leaving this unset means ANYONE who learns a file's relative path
# (nanoid key) can fetch it with no auth — GLB/STL models, QC photos, chat
# images — across tenants. Set this to 1 in production. Prerequisite: bump the
# signed-URL TTL in storage.ts (SIGNED_URL_DEFAULT_TTL_SECONDS) high enough that
# already-emailed image URLs don't 401 before recipients open them, then flip.
FILES_REQUIRE_SIGNATURE=
# Optional: separate secret for file signatures. Falls back to AUTH_SECRET.
FILES_SIGNING_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Yurtici Kargo
YURTICI_WS_USERNAME=
YURTICI_WS_PASSWORD=
YURTICI_TEST_MODE=1

# Cloudflare Turnstile (bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Phone OTP verification (anti-abuse, Phase 6). The generation gate stays OFF
# until PHONE_VERIFICATION_REQUIRED=1. Without Netgsm creds the OTP "sends" to
# the server log (dev/testing). Provider is swappable — see src/lib/services/sms.
PHONE_VERIFICATION_REQUIRED=
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_HEADER=

# App (production: https://figurunica.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Storage
UPLOAD_DIR=./uploads

# ─── Analytics & Marketing Tags ─────────────────────────────────────────────
# All optional. When an ID is unset the corresponding tag/event becomes a no-op,
# so the analytics stack is safe to ship before the marketing accounts exist.
#
# Google Tag Manager container (preferred entry point — fan out GA4/pixels from
# inside the container if you use it). Format: GTM-XXXXXX
NEXT_PUBLIC_GTM_ID=
# GA4 Measurement ID (G-XXXXXXXXXX). Loaded directly via gtag.js when GTM is not
# set; otherwise let the GTM container own GA4.
NEXT_PUBLIC_GA4_ID=
# Meta (Facebook) Pixel ID + Conversions API access token (server-side events).
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional: surfaces server events in Meta Events Manager → Test Events.
META_CAPI_TEST_EVENT_CODE=
# TikTok Pixel ID + Events API token (server-side events).
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_API_TOKEN=
# GA4 Measurement Protocol api_secret (server-side purchase import). Create under
# GA4 Admin → Data Streams → Measurement Protocol API secrets.
GA4_API_SECRET=
# Mirror funnel events to the browser console + log server forwards (staging).
NEXT_PUBLIC_ANALYTICS_DEBUG=
# analytics_events retention (days). A daily worker prunes older rows. Default 180.
ANALYTICS_RETENTION_DAYS=
# Force-enable the on-screen DebugConsole in production (off by default).
NEXT_PUBLIC_DEBUG_CONSOLE=

# ─── Sentry (error monitoring) ──────────────────────────────────────────────
# Public browser+server DSN. When unset, Sentry is fully disabled (no overhead,
# no build plugin). Errors are only reported when NODE_ENV=production.
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload (optional) — needs all three. Generate a token at
# sentry.io → Settings → Auth Tokens (project:releases scope).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Trace/replay sampling (0..1). Defaults: traces 0.1, replay 0.
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=
