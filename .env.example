# Redis
REDIS_URL=redis://localhost:6379

# WhatsApp
WHATSAPP_PHONE=905XXXXXXXXX

# AI Provider (Meshy.ai)
MESHY_API_KEY=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Figurine Studio <siparis@figurinestudio.com>

# Auth
AUTH_SECRET=generate-a-random-secret-here
