# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# python venv
.venv/

# backups
backup_*.sql

# uploads
/uploads

# drizzle: SQL migrations MUST be committed so deploys are reproducible and
# code review can see schema changes. We ignore only the local cache.
/drizzle/meta/_journal.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
