# Database (Local PostgreSQL)
DATABASE_URL=postgresql://printer:printer@localhost:5432/printer

# Redis
REDIS_URL=redis://localhost:6379

# PayTR
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
